{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@common/*": ["common/*"]
    },
    "target": "es2016",
    "module": "commonjs",
    "types": ["cypress-plugin-api", "node"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}
