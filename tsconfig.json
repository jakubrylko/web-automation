{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@common/*": ["common/*"]
    },
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "commonjs",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES6",
    "types": ["cypress-plugin-api", "node"]
  },
  "include": ["cypress", "playwright", "types/*.d.ts"]
}
